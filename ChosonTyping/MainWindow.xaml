<Window x:Class="ChosonTyping.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="최승대" Width="1100" Height="800"
        MinWidth="980" MinHeight="700"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{DynamicResource Paper}" FontFamily="{StaticResource Main}"
        WindowStartupLocation="CenterScreen">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="6"
                      GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border x:Name="Shell" BorderBrush="{DynamicResource Hair}" BorderThickness="1,0,1,1"
            Background="{DynamicResource Paper}">
        <Grid>
            <DockPanel>
                <!-- 창머리: 왼쪽엔 련습 중에만 보이는 작은 로고, 오른쪽엔 판·설정·창단추 (경계선 없음) -->
                <Border DockPanel.Dock="Top" Padding="16,10,10,10"
                        Background="{DynamicResource Paper}"
                        MouseLeftButtonDown="AppBar_MouseDown">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                            <Image x:Name="LogoImage" Height="26" Visibility="Hidden"
                                   RenderOptions.BitmapScalingMode="HighQuality" VerticalAlignment="Center"/>
                            <TextBlock x:Name="WordmarkText" FontSize="15" FontWeight="ExtraBold"
                                       Foreground="{DynamicResource Ink}" VerticalAlignment="Center"
                                       Visibility="Collapsed">
                                <Run Text="최승대"/><Run Text="." Foreground="{DynamicResource Accent}"/>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="VersionText" FontSize="12" Foreground="{DynamicResource Faint}"
                                       VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <Button x:Name="GearBtn" Style="{StaticResource CaptionButton}"
                                    AutomationProperties.Name="설정" Click="GearBtn_Click">
                                <Path Width="14" Height="14" Stretch="Uniform" Fill="{DynamicResource Mid}"
                                      Data="M10.34,3.46 L9.81,0.71 14.19,0.71 13.66,3.46 16.87,4.79 18.43,2.47 21.53,5.57 19.21,7.13 20.54,10.34 23.29,9.81 23.29,14.19 20.54,13.66 19.21,16.87 21.53,18.43 18.43,21.53 16.87,19.21 13.66,20.54 14.19,23.29 9.81,23.29 10.34,20.54 7.13,19.21 5.57,21.53 2.47,18.43 4.79,16.87 3.46,13.66 0.71,14.19 0.71,9.81 3.46,10.34 4.79,7.13 2.47,5.57 5.57,2.47 7.13,4.79 Z M16.6,12 A4.6,4.6 0 1 1 7.4,12 A4.6,4.6 0 1 1 16.6,12 Z"/>
                            </Button>
                            <Popup x:Name="SettingsPopup" AllowsTransparency="True" StaysOpen="False"
                                   PopupAnimation="Fade" PlacementTarget="{Binding ElementName=GearBtn}">
                                <Grid Margin="14">
                                    <Border CornerRadius="12" Background="{DynamicResource Paper}"
                                            BorderBrush="{DynamicResource Hair}" BorderThickness="1">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.3"/>
                                        </Border.Effect>
                                    </Border>
                                    <Border CornerRadius="12" Padding="18,15,18,16">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,9">
                                                <TextBlock x:Name="PopupLangLabel" Style="{StaticResource Label}"
                                                           Width="76" VerticalAlignment="Center"/>
                                                <StackPanel x:Name="PopupLangBar" Orientation="Horizontal"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="PopupThemeLabel" Style="{StaticResource Label}"
                                                           Width="76" VerticalAlignment="Center"/>
                                                <StackPanel x:Name="PopupThemeBar" Orientation="Horizontal"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Popup>
                            <Button x:Name="MinBtn" Style="{StaticResource CaptionButton}" Content="─"
                                    Click="MinBtn_Click"/>
                            <Button x:Name="MaxBtn" Style="{StaticResource CaptionButton}" Content="□"
                                    Click="MaxBtn_Click"/>
                            <Button x:Name="CloseBtn" Style="{StaticResource CloseButton}" Content="✕"
                                    Click="CloseBtn_Click"/>
                        </StackPanel>
                        <Border/>
                    </DockPanel>
                </Border>
                <ContentControl x:Name="Host"/>
            </DockPanel>
            <!-- 화면 전환 때 로고가 날아가는 덮개층 -->
            <Canvas x:Name="Fx" IsHitTestVisible="False"/>
        </Grid>
    </Border>
</Window>
