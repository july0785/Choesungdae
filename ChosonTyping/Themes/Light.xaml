<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 밝은 화면 — 백토 바탕에 먹, 진홍·남빛 (인공기의 붉음·남빛·흰빛의 재해석) -->
    <SolidColorBrush x:Key="Paper"   Color="#FCFBF8"/>
    <SolidColorBrush x:Key="Ink"     Color="#1B1917"/>
    <SolidColorBrush x:Key="Mid"     Color="#756E66"/>
    <SolidColorBrush x:Key="Faint"   Color="#B5ACA2"/>
    <SolidColorBrush x:Key="Hair"    Color="#E9E2D8"/>
    <SolidColorBrush x:Key="Soft"    Color="#F4EEE3"/>
    <SolidColorBrush x:Key="Red"     Color="#BE2A33"/>
    <SolidColorBrush x:Key="RedDeep" Color="#9E2028"/>
    <SolidColorBrush x:Key="Blue"    Color="#31588A"/>
</ResourceDictionary>
