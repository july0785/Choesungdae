<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 밝은 화면 — 아주 살짝 푸른 흰 바탕에 먹, 청·물빛 (인공기 남빛의 재해석) -->
    <SolidColorBrush x:Key="Paper"      Color="#FBFCFE"/>
    <SolidColorBrush x:Key="Ink"        Color="#1B1E24"/>
    <SolidColorBrush x:Key="Mid"        Color="#5D6674"/>
    <SolidColorBrush x:Key="Faint"      Color="#9CA6B4"/>
    <SolidColorBrush x:Key="Hair"       Color="#E0E6EE"/>
    <SolidColorBrush x:Key="Soft"       Color="#EFF3F8"/>
    <SolidColorBrush x:Key="Accent"     Color="#2C5C99"/>
    <SolidColorBrush x:Key="AccentDeep" Color="#234C80"/>
    <SolidColorBrush x:Key="Sky"        Color="#7CA6D4"/>
    <SolidColorBrush x:Key="Wrong"      Color="#B23A34"/>
</ResourceDictionary>
