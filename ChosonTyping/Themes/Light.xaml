<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 밝은 화면 — 백토 바탕에 먹, 청·물빛 (인공기 남빛의 재해석) -->
    <SolidColorBrush x:Key="Paper"      Color="#FCFBF8"/>
    <SolidColorBrush x:Key="Ink"        Color="#1B1917"/>
    <SolidColorBrush x:Key="Mid"        Color="#756E66"/>
    <SolidColorBrush x:Key="Faint"      Color="#B5ACA2"/>
    <SolidColorBrush x:Key="Hair"       Color="#E9E2D8"/>
    <SolidColorBrush x:Key="Soft"       Color="#F4EEE3"/>
    <SolidColorBrush x:Key="Accent"     Color="#2C5C99"/>
    <SolidColorBrush x:Key="AccentDeep" Color="#234C80"/>
    <SolidColorBrush x:Key="Sky"        Color="#7CA6D4"/>
    <SolidColorBrush x:Key="Wrong"      Color="#B23A34"/>
</ResourceDictionary>
