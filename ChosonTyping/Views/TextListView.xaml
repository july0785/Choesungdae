<UserControl x:Class="ChosonTyping.Views.TextListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,26,40,40" MaxWidth="880">
            <Button Style="{StaticResource QuietButton}" Content="← 시작화면"
                    HorizontalAlignment="Left" Click="Back_Click"/>
            <TextBlock x:Name="TitleText" Style="{StaticResource H1}" Margin="0,14,0,4"/>
            <TextBlock x:Name="SubText" Style="{StaticResource Body}"
                       Foreground="{DynamicResource Mid}" Margin="0,0,0,24"/>

            <TextBlock Style="{StaticResource Label}" Text="글 고르기" Margin="0,0,0,10"/>
            <StackPanel x:Name="TextList"/>

            <Button x:Name="ImportBtn" Style="{StaticResource AccentButton}" Content="불러오기 (.txt)"
                    HorizontalAlignment="Left" Margin="0,24,0,0" Padding="22,10" Click="Import_Click"/>
            <TextBlock FontSize="12" Foreground="{DynamicResource Faint}" Margin="0,10,0,0"
                       Text="불러온 글은 data\imported\ 에 전용형식(.ctp)으로 잠겨 저장되고, 다시 열 때마다 검사합니다."/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
