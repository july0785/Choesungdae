<UserControl x:Class="ChosonTyping.Views.WordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ChosonTyping.Views"
             Focusable="True">
    <DockPanel>
        <views:StatsBar x:Name="Stats" DockPanel.Dock="Bottom"/>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="40,18,40,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource QuietButton}"
                            Content="← 시작화면" HorizontalAlignment="Left" Click="Back_Click"/>
                    <TextBlock x:Name="TitleText" Grid.Column="1" FontSize="13" FontWeight="Bold"
                               Foreground="{DynamicResource Mid}" VerticalAlignment="Center"/>
                </Grid>

                <TextBlock x:Name="TargetText" FontSize="52" FontWeight="ExtraBold"
                           HorizontalAlignment="Center" Margin="0,26,0,4"/>
                <TextBlock x:Name="TypedText" FontSize="24" HorizontalAlignment="Center"
                           Foreground="{DynamicResource Mid}" Margin="0,0,0,6" MinHeight="34"/>
                <TextBlock x:Name="HintText" FontSize="12.5" HorizontalAlignment="Center"
                           Foreground="{DynamicResource Faint}" Margin="0,0,0,20"/>

                <views:KeyboardControl x:Name="Kb"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
