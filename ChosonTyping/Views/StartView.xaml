<UserControl x:Class="ChosonTyping.Views.StartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,10,40,40">

            <!-- 머리: 큰 로고는 가운데, 설정(언어·화면형식)은 오른쪽 우 -->
            <Grid MinHeight="150" Margin="0,0,0,14">
                <Image x:Name="BigLogo" Height="110" HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="Collapsed" RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock x:Name="BigWordmark" FontSize="66" FontWeight="ExtraBold"
                           Foreground="{DynamicResource Ink}" Visibility="Collapsed"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <Border x:Name="SettingsCard" HorizontalAlignment="Right" VerticalAlignment="Top"
                        CornerRadius="12" BorderBrush="{DynamicResource Hair}" BorderThickness="1"
                        Background="{DynamicResource Soft}" Padding="16,13,16,14">
                    <StackPanel>
                        <TextBlock Text="⚙" FontSize="14" Foreground="{DynamicResource Faint}"
                                   Margin="0,0,0,9"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                            <TextBlock x:Name="LangLabel" Style="{StaticResource Label}"
                                       Width="76" VerticalAlignment="Center"/>
                            <StackPanel x:Name="LangBar" Orientation="Horizontal"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="ThemeLabel" Style="{StaticResource Label}"
                                       Width="76" VerticalAlignment="Center"/>
                            <StackPanel x:Name="ThemeBar" Orientation="Horizontal"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock x:Name="LayoutsLabel" Style="{StaticResource Label}" Margin="0,0,0,10"/>
            <UniformGrid x:Name="LayoutCards" Columns="3"/>

            <TextBlock x:Name="StagesLabel" Style="{StaticResource Label}" Margin="0,28,0,10"/>
            <StackPanel x:Name="StageList"/>

            <Button x:Name="StartBtn" Style="{StaticResource AccentButton}"
                    HorizontalAlignment="Left" Margin="0,26,0,0" Click="StartBtn_Click"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
