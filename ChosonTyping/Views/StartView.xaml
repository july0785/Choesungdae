<UserControl x:Class="ChosonTyping.Views.StartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,26,40,40" MaxWidth="880">
            <TextBlock Style="{StaticResource H1}" Text="오늘도 한 글쇠씩." Margin="0,10,0,4"/>
            <TextBlock Style="{StaticResource Body}" Foreground="{StaticResource Mid}"
                       Text="건반배렬을 고르고, 련습단계를 골라 시작하십시오." Margin="0,0,0,26"/>

            <TextBlock Style="{StaticResource Label}" Text="건반배렬" Margin="0,0,0,10"/>
            <UniformGrid x:Name="LayoutCards" Columns="3"/>

            <TextBlock Style="{StaticResource Label}" Text="련습단계" Margin="0,28,0,10"/>
            <StackPanel x:Name="StageList"/>

            <Button x:Name="StartBtn" Style="{StaticResource RedButton}" Content="련습 시작"
                    HorizontalAlignment="Left" Margin="0,26,0,0" Click="StartBtn_Click"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
